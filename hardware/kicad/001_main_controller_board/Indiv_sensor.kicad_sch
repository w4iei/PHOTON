		(uuid "3234cc36-42eb-4931-ad82-cf21b486b7f1")
	)
	(text "Note, reducing the value of R5 increases the LED output strength. \nThe sensor will work at a longer range, but at the expense of \nsensitivity to near field movement. \n\nThese values have been tuned for operation in the 0.5-3CM sensing distance at 3.3V\nI_LED = (3.3V-1.47V)/(68+0.45 ohms) =~ 27 mA\nThis works fine for bursts ~1-5ms or continuous operation"
		(exclude_from_sim no)
		(at 128.27 86.106 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "c18f2729-492c-4110-9aa7-56328eeac63c")
	)
