	(text "RS485 needs a termination at the end of the bus.\nA middle device with both left and right connected \nneeds to have both ends unterminated. \nBut if it's at the end of the bus, and JST right is used,\nthen drive RS485_TERM high. \nIf end-fed by JST left, then right must be terminated"
		(exclude_from_sim no)
		(at 124.46 194.056 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "62a95ff3-ecdd-443d-90c5-10f36a4faf90")
	)
